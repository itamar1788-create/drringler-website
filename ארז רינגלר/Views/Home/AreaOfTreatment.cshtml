
@{
	ViewData["Title"] = "תחומי טיפול";
}
<section class="treat-secsion">
	<h1 class="treatments-title">תחומי מומחיות וטיפול</h1>
	<div style="display:flex; flex-direction:row; gap:60px; margin-bottom:50px; margin-top:40px;";>
	<div class="treatments-card">
		<div class="treatment-icon"><i class="fa-solid fa-brain"></i></div>
		<h2>שיקום נירולוגי</h2>
		<p> טיפול בפרקינסון, הפרעות תנועה<br>ושיפור תפקוד יום יומי</p>
